# ============================================================
# MORNING BRIEFING — Environment Variable Template
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- Required ---
ANTHROPIC_API_KEY=your_anthropic_api_key

# --- AI model (default: claude-haiku-4-5) ---
# Cheapest current model. Set to claude-sonnet-4-6 for higher quality (~3x cost).
CLAUDE_MODEL=claude-haiku-4-5
# Max output tokens per section call
CLAUDE_MAX_TOKENS=2048

# --- Briefing style ---
# "digest" = zero Claude cost; headlines + Finnhub/RSS/data feeds only (default)
# "light" = concise AI analysis (~$0.04/run, 9 Claude calls)
# "full" = deep institutional AI analysis (~$0.10/run)
BRIEFING_MODE=digest
# Skip Saturdays and Sundays (in TIMEZONE)
WEEKDAYS_ONLY=true

# --- Synthesis usage (one email/day) ---
# VERIFY_SECTIONS=true enables an extra fact-check pass per section (more API calls).
VERIFY_SECTIONS=false
# Optional: verify only key sections (fewer calls). Comma-separated keys:
# markets_macro, corporate_earnings, technology_ai, healthcare, industrials,
# energy_commodities, geopolitical_risk, economic_data, what_to_watch
VERIFY_ONLY_SECTIONS=markets_macro,corporate_earnings,economic_data
# Pause between section calls (seconds)
SECTION_DELAY_SEC=1

# --- Email delivery: SMTP (Gmail app password) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# --- Email addresses ---
SENDER_EMAIL=you@gmail.com
RECIPIENT_EMAILS=you@company.com,colleague@company.com
ADMIN_EMAIL=admin@yourdomain.com

# --- SendGrid (optional alternative to SMTP) ---
# SENDGRID_API_KEY=SG....

# --- Data feeds (free API keys) ---
FINNHUB_API_KEY=your_finnhub_api_key
FRED_API_KEY=your_fred_api_key

# --- Schedule (weekdays at HOUR:MINUTE in TIMEZONE) ---
TIMEZONE=America/New_York
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=30

# --- Footer ---
UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
