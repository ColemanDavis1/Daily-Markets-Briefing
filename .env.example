# ============================================================
# MORNING BRIEFING — Environment Variable Template
# Copy to .env and fill in your values. Never commit .env.
# ============================================================

# --- Required ---
GOOGLE_API_KEY=your_google_ai_studio_key

# --- AI model (default: gemini-2.5-flash) ---
GEMINI_MODEL=gemini-2.5-flash

# --- Gemini usage (one email/day) ---
# VERIFY_SECTIONS=true enables fact-check pass (extra API call per section)
VERIFY_SECTIONS=false
# Optional: verify only key sections (fewer calls). Comma-separated keys:
# markets_macro, corporate_earnings, technology_ai, healthcare, industrials,
# energy_commodities, geopolitical_risk, economic_data, what_to_watch
VERIFY_ONLY_SECTIONS=markets_macro,corporate_earnings,economic_data
GEMINI_SECTION_DELAY_SEC=4

# --- SendGrid (primary email delivery) ---
SENDGRID_API_KEY=SG....

# --- Email addresses ---
SENDER_EMAIL=briefing@yourdomain.com
RECIPIENT_EMAILS=you@company.com,colleague@company.com
ADMIN_EMAIL=admin@yourdomain.com

# --- SMTP fallback (optional — used if SendGrid is unavailable) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASSWORD=your-app-password

# --- Schedule (weekdays at HOUR:MINUTE in TIMEZONE) ---
TIMEZONE=America/New_York
SCHEDULE_HOUR=9
SCHEDULE_MINUTE=30

# --- Footer ---
UNSUBSCRIBE_URL=https://yourdomain.com/unsubscribe
